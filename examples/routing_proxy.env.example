# CascadeFlow Routing Proxy - Environment Variables
# ===================================================
#
# Copy this file to .env and fill in your API keys
#
# cp routing_proxy.env.example .env

# ═══════════════════════════════════════════════════════════════════════════
# CASCADEFLOW API KEY (REQUIRED)
# ═══════════════════════════════════════════════════════════════════════════
#
# Set a secret API key for authenticating requests to the proxy
# Generate a secure random key: python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# If not set, the proxy will accept all requests (NOT RECOMMENDED for production)

CASCADEFLOW_API_KEY=your-secret-api-key-here

# ═══════════════════════════════════════════════════════════════════════════
# PROVIDER API KEYS (AT LEAST ONE REQUIRED)
# ═══════════════════════════════════════════════════════════════════════════

# OpenAI API Key
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Anthropic API Key
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Groq API Key (Optional - for ultra-fast inference)
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# ═══════════════════════════════════════════════════════════════════════════
# OPTIONAL SETTINGS
# ═══════════════════════════════════════════════════════════════════════════

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Server host (default: 0.0.0.0)
HOST=0.0.0.0

# Server port (default: 8000)
PORT=8000

# ═══════════════════════════════════════════════════════════════════════════
# CLAUDE CODE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════
#
# To use with Claude Code, set these environment variables in your shell:
#
#   export ANTHROPIC_BASE_URL="http://localhost:8000"
#   export ANTHROPIC_API_KEY="your-secret-api-key-here"
#
# Claude Code will now route all requests through CascadeFlow with automatic
# cascade routing and cost optimization!
#
# Expected savings: 40-85% cost reduction with maintained quality
#
